# ---------------------------------------------------------------------------
# Local run configuration -- copy this file to ".env" and edit the paths.
#
#   cp .env.example .env
#   # edit .env, then load it before running:
#   set -a; source .env; set +a
#
# Nothing in src/ needs to be edited or commented out to run locally: every
# path is read from these environment variables (see src/config.py). The only
# Colab-specific code is the drive.mount() cell in the notebooks, which you
# simply do not run locally.
# ---------------------------------------------------------------------------

# REQUIRED: root that contains species/, background/, field_recordings/, outputs/
# (the layout in the README "Data Layout" section). Use an ABSOLUTE path.
PRIMATE_DATA_ROOT=/absolute/path/to/primates-data

# REQUIRED to reproduce the published V10 model. The code default is "gap";
# the production head is the temporal-frequency CRNN.
PRIMATE_MODEL_POOLING=temporal_freq

# OPTIONAL overrides -- only set these if your folders live somewhere other
# than the defaults below (all relative to PRIMATE_DATA_ROOT).
#   species/ and background/ live directly under here:
# PRIMATE_AUDIO_ROOT=/absolute/path/to/primates-data
#   continuous long recordings (default: PRIMATE_DATA_ROOT/long_audio):
# PRIMATE_LONG_AUDIO_ROOT=/absolute/path/to/primates-data/long_audio
#   IPA station folders IPA1ST, IPA2ST, ... (default: PRIMATE_DATA_ROOT/field_recordings):
# PRIMATE_IPA_ROOT=/absolute/path/to/primates-data/field_recordings
#   where models, detection CSVs and clips are written (default: PRIMATE_DATA_ROOT/outputs):
# PRIMATE_OUTPUT_ROOT=/absolute/path/to/primates-data/outputs
